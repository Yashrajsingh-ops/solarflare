# Copy this file to .env and fill in your values.
# The app reads these via os.getenv() — no extra library needed.

# Database
# SQLite (default — works out of the box, no setup required)
DATABASE_URL=sqlite:///./solar_flare.db

# PostgreSQL (uncomment and edit for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/solar_flare

# Server
HOST=0.0.0.0
PORT=8000
